# =====================================================
# ENVIRONMENT VARIABLES - Company Brain & Project Brain
# =====================================================

# Copy this file to .env.local and fill in your values
# DO NOT commit .env.local to version control

# =====================================================
# SUPABASE CONFIGURATION
# =====================================================

# Get these from: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# =====================================================
# GOOGLE GEMINI API
# =====================================================

# Get your API key from: https://ai.google.dev/
# Used for generating 768-dimensional vector embeddings
# Model: text-embedding-004
NEXT_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here

# =====================================================
# JWT SECRET
# =====================================================

# Generate a random 32+ character string for JWT signing
JWT_SECRET=your_jwt_secret_here

# =====================================================
# NOTES
# =====================================================

# 1. NEXT_PUBLIC_SUPABASE_URL
#    - Your Supabase project URL
#    - Format: https://xxxxxxxxxxxxx.supabase.co
#
# 2. NEXT_PUBLIC_SUPABASE_ANON_KEY
#    - Public anonymous key for client-side access
#    - Safe to use in frontend code
#    - Has Row Level Security (RLS) restrictions
#
# 3. SUPABASE_SERVICE_ROLE_KEY
#    - Server-side only key with full database access
#    - NEVER expose in client-side code
#    - Used for admin operations and Edge Functions
#
# 4. NEXT_PUBLIC_GEMINI_API_KEY
#    - Your Google Gemini API key
#    - Used for generating text embeddings in the frontend
#    - Monitor usage at: https://console.cloud.google.com/
#
# 5. JWT_SECRET
#    - Secret key for JWT token signing/verification
#    - Generate using: openssl rand -base64 64
#
# For Edge Functions:
#    - Set GEMINI_API_KEY in Supabase Dashboard → Edge Functions → Secrets
#    - SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are automatically available

# =====================================================
# SECURITY REMINDERS
# =====================================================

# ✅ DO:
# - Keep .env.local in .gitignore
# - Use different keys for dev/staging/production
# - Rotate API keys periodically
# - Monitor API usage for anomalies
#
# ❌ DON'T:
# - Commit .env.local to git
# - Share API keys publicly
# - Use production keys in development
# - Expose SUPABASE_SERVICE_ROLE_KEY on frontend
